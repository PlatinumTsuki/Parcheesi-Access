<Window x:Class="Parcheesi.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Parcheesi.App"
        xmlns:vm="clr-namespace:Parcheesi.App.ViewModels"
        xmlns:game="clr-namespace:Parcheesi.App.Game"
        mc:Ignorable="d"
        Title="Parcheesi Access"
        Height="900" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BoardBg}"
        x:Name="MainWindowRoot"
        AutomationProperties.Name="Parcheesi Access — Jeu de Parcheesi accessible">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:VolumeToPercentConverter x:Key="VolToPct" />
        <Style x:Key="BoardCellButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PanelBg}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="1" />
            <Setter Property="MinWidth" Value="32" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle">
                <Setter.Value>
                    <Style>
                        <Setter Property="Control.Template">
                            <Setter.Value>
                                <ControlTemplate>
                                    <Rectangle Stroke="{StaticResource AccentBrush}" StrokeThickness="3" />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="20,15,20,5">
            <TextBlock Text="Parcheesi Access"
                       FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}" />
            <TextBlock x:Name="TurnInfoText"
                       Text="{Binding TurnInfo}"
                       FontSize="14"
                       Margin="0,4,0,0"
                       Foreground="{StaticResource MutedBrush}"
                       AutomationProperties.LiveSetting="Polite"
                       AutomationProperties.Name="État du tour" />
            <TextBlock x:Name="DiceInfoText"
                       Text="{Binding DiceInfo}"
                       FontSize="14"
                       Margin="0,2,0,0"
                       Foreground="{StaticResource AccentBrush}"
                       AutomationProperties.LiveSetting="Polite"
                       AutomationProperties.Name="Dés" />
        </StackPanel>

        <TextBlock x:Name="LiveAnnouncerText"
                   Grid.Row="0"
                   Text=""
                   Width="1" Height="1"
                   Opacity="0"
                   Focusable="False"
                   AutomationProperties.LiveSetting="Assertive" />

        <Grid Grid.Row="1" Margin="20,5,20,15">

            <ScrollViewer x:Name="SetupPanel"
                          Visibility="{Binding IsInSetup, Converter={StaticResource BoolToVis}}"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          KeyboardNavigation.TabNavigation="Cycle">
                <StackPanel HorizontalAlignment="Center"
                            MaxWidth="540"
                            Margin="20">

                    <!-- En-tête : statut rapide -->
                    <TextBlock x:Name="MenuStatusText"
                               Text="{Binding MenuStatusLine}"
                               FontSize="13"
                               TextAlignment="Center"
                               Foreground="{StaticResource MutedBrush}"
                               Margin="0,0,0,15"
                               TextWrapping="Wrap"
                               AutomationProperties.Name="Statut" />

                    <!-- Section : Reprendre une partie sauvegardée -->
                    <Border x:Name="ResumeSection"
                            Visibility="Collapsed"
                            Background="#1E2D1E"
                            BorderBrush="#3FB950"
                            BorderThickness="2"
                            CornerRadius="8"
                            Padding="14"
                            Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock x:Name="ResumeSectionTitle"
                                       Text="🔄 Une partie est en cours"
                                       FontSize="16" FontWeight="Bold"
                                       Foreground="#3FB950"
                                       Margin="0,0,0,8" />
                            <Button x:Name="ResumeButton"
                                    Content="Reprendre la partie sauvegardée"
                                    Click="ResumeButton_Click"
                                    Background="#3FB950"
                                    Foreground="White"
                                    FontSize="15"
                                    Padding="12,8"
                                    HorizontalAlignment="Stretch" />
                        </StackPanel>
                    </Border>

                    <!-- Section : Nouvelle partie -->
                    <Border Background="{StaticResource PanelBg}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="14"
                            Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock x:Name="NewGameTitle"
                                       Text="🎲 Nouvelle partie"
                                       FontSize="16" FontWeight="Bold"
                                       Margin="0,0,0,12" />

                            <Label x:Name="OpponentsLabel"
                                   Content="Adversaires :"
                                   Target="{Binding ElementName=GameModeCombo}"
                                   Foreground="{StaticResource TextBrush}" />
                            <ComboBox x:Name="GameModeCombo"
                                      SelectedIndex="0"
                                      SelectionChanged="GameModeCombo_Changed"
                                      Margin="0,0,0,10"
                                      Padding="8,6"
                                      AutomationProperties.Name="Mode de jeu, choisis le nombre d'adversaires">
                                <ComboBoxItem x:Name="GameModeSolo1" Content="Solo contre 1 ordinateur (2 joueurs : tu es Rouge)" />
                                <ComboBoxItem x:Name="GameModeSolo2" Content="Solo contre 2 ordinateurs (3 joueurs)" />
                                <ComboBoxItem x:Name="GameModeSolo3" Content="Solo contre 3 ordinateurs (4 joueurs)" />
                                <ComboBoxItem x:Name="GameModeHotseat2" Content="2 humains, hot-seat (sans IA)" />
                                <ComboBoxItem x:Name="GameModeHotseat3" Content="3 humains, hot-seat (sans IA)" />
                                <ComboBoxItem x:Name="GameModeHotseat4" Content="4 humains, hot-seat (sans IA)" />
                            </ComboBox>

                            <Label x:Name="DifficultyLabel"
                                   Content="Niveau de l'ordinateur :"
                                   Target="{Binding ElementName=DifficultyCombo}"
                                   Foreground="{StaticResource TextBrush}" />
                            <ComboBox x:Name="DifficultyCombo"
                                      SelectedIndex="1"
                                      Margin="0,0,0,14"
                                      Padding="8,6"
                                      AutomationProperties.Name="Niveau de difficulté de l'ordinateur">
                                <ComboBoxItem x:Name="DifficultyEasy" Content="Facile — joue presque au hasard, détente" />
                                <ComboBoxItem x:Name="DifficultyMedium" Content="Moyen — stratégie tactique" />
                                <ComboBoxItem x:Name="DifficultyHard" Content="Difficile — anticipe les captures, vrai défi" />
                            </ComboBox>

                            <Expander x:Name="CustomizeExpander"
                                      Header="Personnaliser les joueurs (optionnel)"
                                      Foreground="{StaticResource TextBrush}"
                                      Margin="0,8,0,12">
                                <StackPanel>
                                    <TextBlock x:Name="CustomizeHint"
                                               TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,8"
                                               Text="Laisse les champs vides pour utiliser les valeurs par défaut. Seuls les joueurs présents dans le mode choisi sont affichés." />

                                    <!-- Slot Rouge (toujours visible) -->
                                    <StackPanel x:Name="PlayerSlotRouge" Margin="0,0,0,10">
                                        <Label x:Name="NameRougeLabel" Content="Ton nom (Rouge)" Target="{Binding ElementName=NameRouge}" Foreground="{StaticResource TextBrush}" />
                                        <TextBox x:Name="NameRouge" Padding="6,4" />
                                    </StackPanel>

                                    <!-- Slot Jaune -->
                                    <StackPanel x:Name="PlayerSlotJaune" Margin="0,0,0,10">
                                        <Label x:Name="NameJauneLabel" Content="Nom du Jaune" Target="{Binding ElementName=NameJaune}" Foreground="{StaticResource TextBrush}" />
                                        <TextBox x:Name="NameJaune" Padding="6,4" Margin="0,0,0,4" />
                                        <StackPanel x:Name="PersonalityJauneRow">
                                            <Label x:Name="PersonalityJauneLabel" Content="Personnalité de l'IA Jaune" Target="{Binding ElementName=PersonalityJaune}" Foreground="{StaticResource MutedBrush}" />
                                            <ComboBox x:Name="PersonalityJaune" Padding="6,4" SelectedIndex="0">
                                                <ComboBoxItem x:Name="PersonalityJauneRandom" Content="Aléatoire (par défaut)" />
                                                <ComboBoxItem x:Name="PersonalityJauneAggressive" Content="L'Aggressive — capture à tout prix, prend des risques" />
                                                <ComboBoxItem x:Name="PersonalityJaunePrudent" Content="La Prudente — défensive, reste sur les cases sûres" />
                                                <ComboBoxItem x:Name="PersonalityJauneCoureur" Content="La Coureuse — fonce vers la maison, ignore les captures" />
                                            </ComboBox>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Slot Bleu -->
                                    <StackPanel x:Name="PlayerSlotBleu" Margin="0,0,0,10">
                                        <Label x:Name="NameBleuLabel" Content="Nom du Bleu" Target="{Binding ElementName=NameBleu}" Foreground="{StaticResource TextBrush}" />
                                        <TextBox x:Name="NameBleu" Padding="6,4" Margin="0,0,0,4" />
                                        <StackPanel x:Name="PersonalityBleuRow">
                                            <Label x:Name="PersonalityBleuLabel" Content="Personnalité de l'IA Bleu" Target="{Binding ElementName=PersonalityBleu}" Foreground="{StaticResource MutedBrush}" />
                                            <ComboBox x:Name="PersonalityBleu" Padding="6,4" SelectedIndex="0">
                                                <ComboBoxItem x:Name="PersonalityBleuRandom" Content="Aléatoire (par défaut)" />
                                                <ComboBoxItem x:Name="PersonalityBleuAggressive" Content="L'Aggressive — capture à tout prix, prend des risques" />
                                                <ComboBoxItem x:Name="PersonalityBleuPrudent" Content="La Prudente — défensive, reste sur les cases sûres" />
                                                <ComboBoxItem x:Name="PersonalityBleuCoureur" Content="La Coureuse — fonce vers la maison, ignore les captures" />
                                            </ComboBox>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Slot Vert -->
                                    <StackPanel x:Name="PlayerSlotVert" Margin="0,0,0,10">
                                        <Label x:Name="NameVertLabel" Content="Nom du Vert" Target="{Binding ElementName=NameVert}" Foreground="{StaticResource TextBrush}" />
                                        <TextBox x:Name="NameVert" Padding="6,4" Margin="0,0,0,4" />
                                        <StackPanel x:Name="PersonalityVertRow">
                                            <Label x:Name="PersonalityVertLabel" Content="Personnalité de l'IA Vert" Target="{Binding ElementName=PersonalityVert}" Foreground="{StaticResource MutedBrush}" />
                                            <ComboBox x:Name="PersonalityVert" Padding="6,4" SelectedIndex="0">
                                                <ComboBoxItem x:Name="PersonalityVertRandom" Content="Aléatoire (par défaut)" />
                                                <ComboBoxItem x:Name="PersonalityVertAggressive" Content="L'Aggressive — capture à tout prix, prend des risques" />
                                                <ComboBoxItem x:Name="PersonalityVertPrudent" Content="La Prudente — défensive, reste sur les cases sûres" />
                                                <ComboBoxItem x:Name="PersonalityVertCoureur" Content="La Coureuse — fonce vers la maison, ignore les captures" />
                                            </ComboBox>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Expander>

                            <Button x:Name="StartButton"
                                    Content="Commencer la partie"
                                    Click="StartButton_Click"
                                    HorizontalAlignment="Stretch"
                                    FontSize="16"
                                    Padding="14,10" />
                        </StackPanel>
                    </Border>

                    <!-- Section : Autres actions -->
                    <Border Background="{StaticResource PanelBg}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="14"
                            Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock x:Name="OthersTitle"
                                       Text="📚 Autres"
                                       FontSize="16" FontWeight="Bold"
                                       Margin="0,0,0,8" />
                            <Button x:Name="TutorialButton"
                                    Content="🎓 Tutoriel audio (recommandé pour la première fois)"
                                    Click="TutorialButton_Click"
                                    Background="#5C7DB5"
                                    Foreground="White"
                                    HorizontalAlignment="Stretch"
                                    Padding="10,8"
                                    Margin="0,0,0,8" />
                            <UniformGrid Columns="2" Rows="2">
                                <Button x:Name="MenuStatsButton" Content="Statistiques" Click="MenuStatsButton_Click" Margin="0,0,2,2" />
                                <Button x:Name="MenuAchievementsButton" Content="Succès" Click="MenuAchievementsButton_Click" Margin="2,0,0,2" />
                                <Button x:Name="MenuSettingsButton" Content="Réglages" Click="MenuSettingsButton_Click" Margin="0,2,2,0" />
                                <Button x:Name="MenuQuitButton" Content="Quitter" Click="QuitButton_Click" Background="#7D3535" Foreground="White" Margin="2,2,0,0" />
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <Expander x:Name="RulesExpander"
                              Header="Lire les règles complètes du Parcheesi"
                              Foreground="{StaticResource TextBrush}">
                        <TextBlock x:Name="RulesText"
                                   TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,0">
                            But : faire rentrer tes 4 pions à la maison.
                            <LineBreak /><LineBreak />
                            Chaque tour, tu lances 2 dés (Espace), choisis un pion (1-4), puis appliques un dé (A pour le 1er, Z pour le 2nd, S pour la somme).
                            <LineBreak /><LineBreak />
                            Pour sortir un pion de la base, il faut un 5 (sur un dé ou en somme).
                            <LineBreak /><LineBreak />
                            Si tu fais un double, tu rejoues. Trois doubles d'affilée et le pion le plus avancé retourne à la base.
                            <LineBreak /><LineBreak />
                            Si tu tombes sur un adversaire (sauf case sûre), tu le captures et gagnes 20 cases bonus à appliquer avec B.
                            <LineBreak /><LineBreak />
                            Quand un pion rentre à la maison, tu gagnes 10 cases bonus.
                        </TextBlock>
                    </Expander>
                </StackPanel>
            </ScrollViewer>

            <Grid x:Name="GamePanel"
                  Visibility="{Binding IsInGame, Converter={StaticResource BoolToVis}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{StaticResource PanelBg}"
                        BorderBrush="{StaticResource AccentBrush}"
                        BorderThickness="3"
                        CornerRadius="6"
                        Padding="8">
                    <Grid x:Name="BoardGrid"
                          KeyboardNavigation.DirectionalNavigation="Contained"
                          KeyboardNavigation.TabNavigation="Once"
                          AutomationProperties.Name="Plateau du jeu — utilise les flèches pour naviguer entre les cases, Tab pour sortir vers les autres zones" />
                </Border>

                <DockPanel Grid.Column="1" Margin="10,0,0,0">

                    <Border DockPanel.Dock="Top"
                            Background="{StaticResource PanelBg}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10"
                            Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock x:Name="MyPiecesTitle"
                                       Text="Mes pions"
                                       FontSize="14" FontWeight="Bold"
                                       Margin="0,0,0,6" />
                            <TextBlock x:Name="MyPiecesText"
                                       Text="{Binding MyPiecesDescription}"
                                       FontFamily="Consolas"
                                       FontSize="13"
                                       Foreground="{StaticResource TextBrush}"
                                       AutomationProperties.LiveSetting="Polite"
                                       AutomationProperties.Name="Mes pions"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border DockPanel.Dock="Top"
                            Background="{StaticResource PanelBg}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10"
                            Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock x:Name="ActionsTitle" Text="Actions" FontSize="14" FontWeight="Bold" Margin="0,0,0,6" />
                            <WrapPanel>
                                <Button x:Name="ActionRollButton" Content="Lancer (Espace)" Click="RollButton_Click" />
                                <Button x:Name="ActionBoardButton" Content="Plateau (L)" Click="ReadBoardButton_Click" />
                                <Button x:Name="ActionOpponentsButton" Content="Adversaires (J)" Click="ReadOpponentsButton_Click" />
                                <Button x:Name="ActionHelpButton" Content="Aide (H)" Click="HelpButton_Click" />
                                <Button x:Name="ActionEndTurnButton" Content="Fin de tour (T)" Click="EndTurnButton_Click" />
                                <Button x:Name="ActionAbandonButton" Content="Abandonner" Click="AbandonButton_Click" Background="#7D6535" Foreground="White" />
                                <Button x:Name="ActionQuitGameButton" Content="Fermer le jeu" Click="QuitButton_Click" Background="#7D3535" Foreground="White" />
                            </WrapPanel>
                            <TextBlock x:Name="ActionsHint"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="11"
                                       Margin="0,8,0,0"
                                       Text="Choisis un pion avec 1-4. Applique avec A (dé 1), Z (dé 2), S (somme), B (bonus)." />
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource PanelBg}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10">
                        <DockPanel>
                            <TextBlock x:Name="JournalTitle" DockPanel.Dock="Top" Text="Journal" FontSize="14" FontWeight="Bold" Margin="0,0,0,6" />
                            <ListBox x:Name="LogList"
                                     ItemsSource="{Binding LogEntries}"
                                     Background="Transparent"
                                     Foreground="{StaticResource TextBrush}"
                                     BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     KeyboardNavigation.DirectionalNavigation="None"
                                     AutomationProperties.Name="Journal de partie — accessible avec Tab uniquement">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" TextWrapping="Wrap" FontSize="12" />
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>

                </DockPanel>
            </Grid>

            <!-- ÉCRAN DES RÉGLAGES -->
            <ScrollViewer x:Name="SettingsPanel"
                          Visibility="{Binding IsInSettings, Converter={StaticResource BoolToVis}}"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel HorizontalAlignment="Center" MaxWidth="640" Margin="20">
                    <TextBlock x:Name="SettingsTitle"
                               Text="⚙️ Réglages"
                               FontSize="22" FontWeight="Bold"
                               TextAlignment="Center"
                               Margin="0,0,0,15" />
                    <TextBlock x:Name="SettingsSubtitle"
                               Text="Tous les changements sont sauvegardés automatiquement."
                               FontSize="12"
                               TextAlignment="Center"
                               Foreground="{StaticResource MutedBrush}"
                               Margin="0,0,0,15" />

                    <!-- Volumes -->
                    <Border Background="{StaticResource PanelBg}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock x:Name="VolumesTitle" Text="🔊 Volumes" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" />

                            <Label x:Name="MasterLabel" Content="Volume général" Target="{Binding ElementName=MasterSlider}" Foreground="{StaticResource TextBrush}" />
                            <Slider x:Name="MasterSlider" Minimum="0" Maximum="100" Value="{Binding Settings.MasterVolume, Converter={StaticResource VolToPct}}" TickFrequency="10" IsSnapToTickEnabled="True" AutoToolTipPlacement="BottomRight" AutomationProperties.Name="Volume général en pourcentage" Margin="0,0,0,8" />

                            <Label x:Name="DiceLabel" Content="Volume des dés" Target="{Binding ElementName=DiceSlider}" Foreground="{StaticResource TextBrush}" />
                            <Slider x:Name="DiceSlider" Minimum="0" Maximum="100" Value="{Binding Settings.DiceVolume, Converter={StaticResource VolToPct}}" TickFrequency="10" IsSnapToTickEnabled="True" AutoToolTipPlacement="BottomRight" AutomationProperties.Name="Volume des dés" Margin="0,0,0,8" />

                            <Label x:Name="MoveLabel" Content="Volume des déplacements de pions" Target="{Binding ElementName=MoveSlider}" Foreground="{StaticResource TextBrush}" />
                            <Slider x:Name="MoveSlider" Minimum="0" Maximum="100" Value="{Binding Settings.MoveVolume, Converter={StaticResource VolToPct}}" TickFrequency="10" IsSnapToTickEnabled="True" AutoToolTipPlacement="BottomRight" AutomationProperties.Name="Volume des déplacements" Margin="0,0,0,8" />

                            <Label x:Name="EventLabel" Content="Volume des événements (capture, maison, sortie)" Target="{Binding ElementName=EventSlider}" Foreground="{StaticResource TextBrush}" />
                            <Slider x:Name="EventSlider" Minimum="0" Maximum="100" Value="{Binding Settings.EventVolume, Converter={StaticResource VolToPct}}" TickFrequency="10" IsSnapToTickEnabled="True" AutoToolTipPlacement="BottomRight" AutomationProperties.Name="Volume des événements" Margin="0,0,0,8" />

                            <Label x:Name="AIVolLabel" Content="Volume des ticks de réflexion de l'ordinateur" Target="{Binding ElementName=AIVolSlider}" Foreground="{StaticResource TextBrush}" />
                            <Slider x:Name="AIVolSlider" Minimum="0" Maximum="100" Value="{Binding Settings.AIThinkVolume, Converter={StaticResource VolToPct}}" TickFrequency="5" IsSnapToTickEnabled="True" AutoToolTipPlacement="BottomRight" AutomationProperties.Name="Volume des ticks de l'ordinateur" Margin="0,0,0,8" />

                            <Label x:Name="NavVolLabel" Content="Volume de la navigation au clavier" Target="{Binding ElementName=NavVolSlider}" Foreground="{StaticResource TextBrush}" />
                            <Slider x:Name="NavVolSlider" Minimum="0" Maximum="100" Value="{Binding Settings.NavigationVolume, Converter={StaticResource VolToPct}}" TickFrequency="10" IsSnapToTickEnabled="True" AutoToolTipPlacement="BottomRight" AutomationProperties.Name="Volume de navigation" Margin="0,0,0,8" />

                            <Label x:Name="AmbMusicLabel" Content="Volume de la musique d'ambiance (Chopin au menu, Satie en jeu)" Target="{Binding ElementName=AmbienceMusicSlider}" Foreground="{StaticResource TextBrush}" />
                            <Slider x:Name="AmbienceMusicSlider" Minimum="0" Maximum="100" Value="{Binding Settings.AmbienceMusicVolume, Converter={StaticResource VolToPct}}" TickFrequency="5" IsSnapToTickEnabled="True" AutoToolTipPlacement="BottomRight" AutomationProperties.Name="Volume de la musique d'ambiance" />
                        </StackPanel>
                    </Border>

                    <!-- Vitesses -->
                    <Border Background="{StaticResource PanelBg}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock x:Name="SpeedsTitle" Text="⚡ Vitesses" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" />

                            <Label x:Name="WalkSpeedLabel" Content="Vitesse du tap-par-case quand un pion bouge" Target="{Binding ElementName=WalkSpeedCombo}" Foreground="{StaticResource TextBrush}" />
                            <ComboBox x:Name="WalkSpeedCombo" SelectionChanged="WalkSpeedCombo_Changed" Margin="0,0,0,10" Padding="8,6">
                                <ComboBoxItem x:Name="WalkSpeedSlow" Tag="200" Content="Lent (un pion met longtemps à traverser)" />
                                <ComboBoxItem x:Name="WalkSpeedModerate" Tag="150" Content="Modéré" />
                                <ComboBoxItem x:Name="WalkSpeedNormal" Tag="110" Content="Normal" IsSelected="True" />
                                <ComboBoxItem x:Name="WalkSpeedFast" Tag="80"  Content="Rapide" />
                                <ComboBoxItem x:Name="WalkSpeedVeryFast" Tag="50"  Content="Très rapide (presque instantané)" />
                            </ComboBox>

                            <Label x:Name="AISpeedLabel" Content="Délai de réflexion de l'ordinateur entre chaque tick" Target="{Binding ElementName=AISpeedCombo}" Foreground="{StaticResource TextBrush}" />
                            <ComboBox x:Name="AISpeedCombo" SelectionChanged="AISpeedCombo_Changed" Padding="8,6">
                                <ComboBoxItem x:Name="AISpeedPatient" Tag="800" Content="Patient (l'ordi prend son temps)" />
                                <ComboBoxItem x:Name="AISpeedNormal" Tag="500" Content="Normal" IsSelected="True" />
                                <ComboBoxItem x:Name="AISpeedQuick" Tag="350" Content="Vif" />
                                <ComboBoxItem x:Name="AISpeedExpress" Tag="200" Content="Express (l'ordi joue vite)" />
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <!-- Timer de tour -->
                    <Border Background="{StaticResource PanelBg}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock x:Name="TimerTitle" Text="⏱ Timer de tour" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" />

                            <Label x:Name="TimerModeLabel" Content="Mode du timer" Target="{Binding ElementName=TimerModeCombo}" Foreground="{StaticResource TextBrush}" />
                            <ComboBox x:Name="TimerModeCombo" SelectionChanged="TimerModeCombo_Changed" Margin="0,0,0,10" Padding="8,6">
                                <ComboBoxItem x:Name="TimerDisabled" Tag="Disabled" Content="Désactivé (par défaut, jeu détendu)" IsSelected="True" />
                                <ComboBoxItem x:Name="TimerRelaxed" Tag="Relaxed"  Content="Détente — 2 minutes par tour" />
                                <ComboBoxItem x:Name="TimerStandard" Tag="Standard" Content="Standard — 60 secondes par tour" />
                                <ComboBoxItem x:Name="TimerFast" Tag="Fast"     Content="Rapide — 30 secondes par tour" />
                            </ComboBox>

                            <Label x:Name="TimerBehaviorLabel" Content="Comportement à l'expiration du timer" Target="{Binding ElementName=TimeoutBehaviorCombo}" Foreground="{StaticResource TextBrush}" />
                            <ComboBox x:Name="TimeoutBehaviorCombo" SelectionChanged="TimeoutBehaviorCombo_Changed" Padding="8,6">
                                <ComboBoxItem x:Name="TimerBehaviorAutoPlay" Tag="AutoPlay" Content="Auto-play : l'ordinateur joue à ta place (recommandé)" IsSelected="True" />
                                <ComboBoxItem x:Name="TimerBehaviorSkip" Tag="SkipTurn" Content="Saut du tour : tu perds ton tour" />
                            </ComboBox>

                            <TextBlock x:Name="TimerHint" TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,0"
                                       Text="En jeu : F2 met en pause, F3 demande le temps restant. Les avertissements audio se déclenchent à mi-temps, à 10 secondes et à 5 secondes." />
                        </StackPanel>
                    </Border>

                    <!-- Comportement -->
                    <Border Background="{StaticResource PanelBg}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock x:Name="BehaviorTitle" Text="🔧 Comportement audio" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" />
                            <CheckBox x:Name="LegalPreviewCheck" IsChecked="{Binding Settings.LegalMovePreviewSounds}" Margin="0,4" Foreground="{StaticResource TextBrush}" Content="Aperçu sonore à la sélection (3 tons cloche/tic indiquant si A, Z et S sont jouables)" />
                            <CheckBox x:Name="OpportunityHintsCheck" IsChecked="{Binding Settings.OpportunityHints}" Margin="0,4" Foreground="{StaticResource TextBrush}" Content="Annoncer les opportunités au lancer (« capture possible », « maison possible »)" />
                            <CheckBox x:Name="ZoneTransitionCheck" IsChecked="{Binding Settings.ZoneTransitionSounds}" Margin="0,4" Foreground="{StaticResource TextBrush}" Content="Sons de transition quand on change de zone en navigant avec les flèches" />
                            <CheckBox x:Name="EdgeBumpCheck" IsChecked="{Binding Settings.EdgeBumpSound}" Margin="0,4" Foreground="{StaticResource TextBrush}" Content="Son d'erreur quand on bute contre le bord du plateau" />
                            <CheckBox x:Name="VerboseCheck" IsChecked="{Binding Settings.VerboseAnnouncements}" Margin="0,4" Foreground="{StaticResource TextBrush}" Content="Annonces longues (mode découverte) au lieu du mode concis" />
                            <CheckBox x:Name="ImmersiveCheck" IsChecked="{Binding Settings.ImmersiveAmbience}" Margin="0,4" Foreground="{StaticResource TextBrush}" Content="Ambiance salon victorien (phrases d'immersion début/fin de partie ; à venir : musique douce et sons de cheminée)" />
                        </StackPanel>
                    </Border>

                    <!-- Langue -->
                    <Border Background="{StaticResource PanelBg}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock x:Name="LanguageTitle" Text="🌐 Langue" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" />
                            <Label x:Name="LanguageLabel" Content="Langue de l'interface" Target="{Binding ElementName=LanguageCombo}" Foreground="{StaticResource TextBrush}" />
                            <ComboBox x:Name="LanguageCombo" SelectionChanged="LanguageCombo_Changed" Padding="8,6" AutomationProperties.Name="Langue de l'interface">
                                <ComboBoxItem Tag="fr" Content="Français" />
                                <ComboBoxItem Tag="en" Content="English" />
                                <ComboBoxItem Tag="es" Content="Español" />
                            </ComboBox>
                            <TextBlock x:Name="LanguageHint" TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,0"
                                       Text="Le changement de langue prend effet au prochain démarrage de l'application." />
                        </StackPanel>
                    </Border>

                    <!-- Actions -->
                    <UniformGrid Columns="2" Margin="0,0,0,15">
                        <Button x:Name="ResetSettingsButton" Content="Réinitialiser aux valeurs par défaut" Click="ResetSettingsButton_Click" Margin="0,0,4,0" Background="#7D6535" Foreground="White" />
                        <Button x:Name="CloseSettingsButton" Content="Retour au menu" Click="CloseSettingsButton_Click" Margin="4,0,0,0" />
                    </UniformGrid>
                </StackPanel>
            </ScrollViewer>

            <!-- ÉCRAN DE FIN DE PARTIE -->
            <ScrollViewer x:Name="EndPanel"
                          Visibility="{Binding IsInEndScreen, Converter={StaticResource BoolToVis}}"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel HorizontalAlignment="Center" MaxWidth="600" Margin="20">
                    <TextBlock x:Name="EndPanelTitle"
                               Text="Fin de partie"
                               FontSize="22" FontWeight="Bold"
                               TextAlignment="Center"
                               Margin="0,0,0,15" />

                    <Border Background="{StaticResource PanelBg}"
                            BorderBrush="{StaticResource AccentBrush}"
                            BorderThickness="2"
                            CornerRadius="8"
                            Padding="16"
                            Margin="0,0,0,15">
                        <TextBlock x:Name="EndGameSummaryText"
                                   Text="{Binding EndGameSummary}"
                                   FontSize="14"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource TextBrush}"
                                   AutomationProperties.Name="Résumé de la partie"
                                   AutomationProperties.LiveSetting="Polite" />
                    </Border>

                    <Border Background="{StaticResource PanelBg}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="14">
                        <StackPanel>
                            <TextBlock x:Name="EndPanelWhatNow"
                                       Text="Que veux-tu faire ?"
                                       FontSize="14" FontWeight="Bold"
                                       Margin="0,0,0,10" />
                            <Button x:Name="ReplayButton"
                                    Content="Rejouer (mêmes paramètres)"
                                    Click="ReplayButton_Click"
                                    HorizontalAlignment="Stretch"
                                    FontSize="15"
                                    Padding="12,10"
                                    Margin="0,0,0,8" />
                            <Button x:Name="NewGameButton"
                                    Content="Nouvelle partie (changer paramètres)"
                                    Click="NewGameButton_Click"
                                    HorizontalAlignment="Stretch"
                                    Padding="10,8"
                                    Margin="0,0,0,8" />
                            <Button x:Name="EndPanelStatsButton"
                                    Content="Voir les statistiques cumulées"
                                    Click="MenuStatsButton_Click"
                                    HorizontalAlignment="Stretch"
                                    Padding="10,8"
                                    Margin="0,0,0,8" />
                            <Button x:Name="EndPanelQuitButton"
                                    Content="Fermer le jeu"
                                    Click="QuitButton_Click"
                                    HorizontalAlignment="Stretch"
                                    Padding="10,8"
                                    Background="#7D3535"
                                    Foreground="White" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
